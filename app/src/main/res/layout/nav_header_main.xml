<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:background="@drawable/bg_gradient_primary"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="16dp">

    <ImageView
        android:id="@+id/header_logo"
        android:layout_width="140dp"
        android:layout_height="52dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/fielddesk_logo_content_description"
        android:src="@drawable/arcom_logo" />

    <TextView
        android:id="@+id/header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/fielddesk_nav_title"
        android:textColor="@color/brand_text"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/header_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/fielddesk_nav_subtitle"
        android:textColor="@color/brand_accent" />
</LinearLayout>
