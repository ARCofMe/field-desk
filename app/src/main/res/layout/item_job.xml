<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:foreground="?attr/selectableItemBackground"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_job_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Customer name • Status"
            android:textColor="@color/brand_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_job_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="123 Main St, City"
            android:textColor="@color/brand_subtle_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/text_job_window"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="8:00-10:00 AM"
            android:textColor="@color/brand_subtle_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/text_job_equipment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Next step"
            android:textColor="@color/brand_text"
            android:textSize="13sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/text_job_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="555-1234"
            android:textColor="@color/brand_subtle_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/text_job_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="2.4 mi away"
            android:textColor="@color/brand_accent"
            android:textSize="13sp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
