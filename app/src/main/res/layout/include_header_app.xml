<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/image_header_logo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:adjustViewBounds="true"
        android:contentDescription="ARCoM logo"
        android:src="@drawable/arcom_logo_sm" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Appliance Repair Center"
            android:textColor="@color/brand_subtle_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_header_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tech App"
            android:textColor="@color/brand_text"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
