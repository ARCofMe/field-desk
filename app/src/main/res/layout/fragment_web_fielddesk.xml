<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/text_web_fielddesk_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FieldDesk web host"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_web_fielddesk_config"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Config state" />

    <Button
        android:id="@+id/button_open_web_fielddesk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Reload web FieldDesk" />

    <ProgressBar
        android:id="@+id/progress_web_fielddesk"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/text_web_fielddesk_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

    <WebView
        android:id="@+id/web_fielddesk"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1" />

</LinearLayout>
