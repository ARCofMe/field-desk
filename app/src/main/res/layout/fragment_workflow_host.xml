<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_primary"
    android:orientation="vertical"
    android:padding="16dp">

    <include layout="@layout/include_header_app" />

    <TextView
        android:id="@+id/text_workflow_host_eyebrow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/fielddesk_guided_workflow"
        android:textColor="@color/brand_accent"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_workflow_host_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/fielddesk_workflow_no_job_title"
        android:textColor="@color/brand_text"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_workflow_host_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/fielddesk_workflow_no_job_summary"
        android:textColor="@color/brand_subtle_text" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/button_workflow_overview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/fielddesk_workflow_tab_overview" />

        <Button
            android:id="@+id/button_workflow_notes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/fielddesk_workflow_tab_notes" />

        <Button
            android:id="@+id/button_workflow_photos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/fielddesk_workflow_tab_photos" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_workflow_empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@android:color/white"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fielddesk_workflow_no_job_title"
            android:textColor="@color/brand_text"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/fielddesk_workflow_no_job_summary"
            android:textColor="@color/brand_subtle_text" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_workflow_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/text_workflow_headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/fielddesk_guided_workflow"
                android:textColor="@color/brand_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_workflow_next_step"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/fielddesk_workflow_no_job_summary"
                android:textColor="@color/brand_subtle_text" />

            <TextView
                android:id="@+id/text_workflow_readiness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/fielddesk_workflow_readiness_default"
                android:textColor="@color/brand_accent"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_workflow_blockers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/fielddesk_workflow_blockers_default"
                android:textColor="@color/brand_subtle_text" />

            <TextView
                android:id="@+id/text_workflow_local_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/fielddesk_workflow_progress_default"
                android:textColor="@color/brand_subtle_text" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/workflow_child_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

</LinearLayout>
