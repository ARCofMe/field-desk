<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- AppCompat/MaterialComponents theme without an action bar; MainActivity supplies its own Toolbar -->
    <style name="Theme.ARCoMTechApp" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/brand_text</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorSecondaryVariant">@color/brand_accent_dark</item>
        <item name="colorOnSecondary">@color/brand_button_text</item>
        <item name="android:statusBarColor">@color/brand_primary_dark</item>
        <item name="android:navigationBarColor">@color/brand_primary_dark</item>
        <item name="android:windowBackground">@color/brand_surface</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="colorSurface">@color/brand_surface_light</item>
        <item name="colorOnSurface">@color/brand_text</item>
        <item name="materialCardViewStyle">@style/Widget.ARCoM.Card</item>
        <item name="toolbarStyle">@style/Widget.ARCoM.Toolbar</item>
        <item name="materialButtonStyle">@style/Widget.ARCoM.Button</item>
        <item name="switchStyle">@style/Widget.ARCoM.Switch</item>
    </style>

    <style name="Theme.ARCoMTechApp.Light" parent="Theme.ARCoMTechApp" />

    <style name="Theme.ARCoMTechApp.Dark" parent="Theme.ARCoMTechApp" />

    <style name="Widget.ARCoM.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/brand_surface_light</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/brand_card_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Medium</item>
    </style>

    <style name="Widget.ARCoM.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/brand_primary</item>
        <item name="titleTextColor">@color/brand_text</item>
        <item name="subtitleTextColor">@color/brand_subtle_text</item>
        <item name="navigationIconTint">@color/brand_text</item>
    </style>

    <style name="Widget.ARCoM.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:insetTop">10dp</item>
        <item name="android:insetBottom">10dp</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="Widget.ARCoM.Switch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="android:thumbTint">@color/brand_accent</item>
        <item name="android:trackTint">@color/brand_accent_dark</item>
    </style>

    <!-- Splash uses a drawable window background to show the full logo -->
    <style name="Theme.ARCoMTechApp.Splash" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>

    <style name="Theme.ARCoMTechApp.Splash.Light" parent="Theme.ARCoMTechApp.Splash" />

    <style name="Theme.ARCoMTechApp.Splash.Dark" parent="Theme.ARCoMTechApp.Splash" />
</resources>
