<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- On-brand gradient backdrop -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/brand_primary_dark"
                android:endColor="@color/brand_primary"
                android:angle="135" />
        </shape>
    </item>
    <!-- Center the full logo without cropping; fix its size so it's never clipped -->
    <item
        android:width="220dp"
        android:height="220dp"
        android:gravity="center">
        <bitmap
            android:gravity="center"
            android:filter="false"
            android:src="@drawable/arcom_logo_sm" />
    </item>
</layer-list>
