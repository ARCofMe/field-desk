<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/brand_primary_dark"
                android:endColor="@color/brand_primary"
                android:angle="135" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:centerX="70%"
                android:centerY="20%"
                android:startColor="#332AC9B0"
                android:endColor="#0012314A" />
        </shape>
    </item>
</layer-list>
